{
  "name": "@hashfund/sdk",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./models": {
      "types": "./src/models/index.ts",
      "import": "./dist/models/index.js",
      "default": "./dist/models/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/models/index.ts --format=esm --minify --treeshake --dts"
  },
  "peerDependencies": {
    "typescript": "latest"
  },
  "dependencies": {
    "@coral-xyz/anchor": "0.29.0",
    "@hashfund/zeroboost": "*",
    "bn.js": "^5.2.1",
    "xior": "^0.6.1"
  }
}
